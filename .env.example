# ============================================
# MBIYO - Configuration Environnement
# ============================================

# Application
NODE_ENV=development
PORT=5000
APP_NAME=Mbiyo
APP_URL=http://localhost:5000

# Base de données PostgreSQL
DATABASE_URL=postgresql://mbiyo_user:mbiyo_password@localhost:5432/mbiyo_db

# JWT
JWT_SECRET=votre_jwt_secret_super_long_et_securise_changez_moi
JWT_REFRESH_SECRET=votre_refresh_secret_super_long_changez_moi
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_URL=redis://localhost:6379

# SerdiPay
SERDIPAY_API_URL=https://api.serdipay.com
SERDIPAY_API_KEY=votre_cle_api_serdipay
SERDIPAY_SECRET_KEY=votre_secret_serdipay
SERDIPAY_WEBHOOK_SECRET=votre_webhook_secret
SERDIPAY_MERCHANT_ID=votre_merchant_id

# Mapbox
MAPBOX_ACCESS_TOKEN=votre_mapbox_token
NEXT_PUBLIC_MAPBOX_TOKEN=votre_mapbox_token

# Firebase (FCM)
FIREBASE_PROJECT_ID=votre_project_id
FIREBASE_CLIENT_EMAIL=votre_client_email
FIREBASE_PRIVATE_KEY=votre_private_key

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Frontend URLs
CLIENT_URL=http://localhost:3000
DRIVER_URL=http://localhost:3001
SUPPLIER_URL=http://localhost:3002
ADMIN_URL=http://localhost:3003

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# Frais de livraison par défaut (en CDF)
DEFAULT_BASE_FEE=2000
DEFAULT_PER_KM_FEE=500
PLATFORM_COMMISSION_RATE=0.15
